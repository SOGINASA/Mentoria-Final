# === База данных ===
# Не задано -> локальный SQLite в back/database/database.db
# DATABASE_URL=sqlite:////app/database/database.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/writeoff

# === CORS (домены фронтенда через запятую) ===
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# === Загрузка фото ===
MAX_UPLOAD_MB=15
API_BASE_URL=http://localhost:5252

# === Распознавание продукции (тип + испорченность) ===
# 1 = включено (нужны ultralytics+torch и веса). 0 = выключить полностью.
RECOGNITION_ENABLED=1
RECOGNITION_CONF=0.3
# Пути к весам YOLO. Локально по умолчанию берутся из соседнего ml/runs.
# В docker задаются в docker-compose.yml (веса монтируются в /models/runs).
# DETECTOR_MODEL_PATH=/models/runs/detect/runs/writeoff_detector-3/weights/best.pt
# CLASSIFIER_MODEL_PATH=/models/runs/classify/runs/writeoff_classifier/weights/best.pt
# GUNICORN_WORKERS=2   # каждый воркер грузит свою копию моделей

# === Iiko ===
# mock = имитация создания акта; real = реальный API (нужны креды ниже)
IIKO_MODE=mock
IIKO_BASE_URL=
IIKO_API_LOGIN=
IIKO_API_TOKEN=
IIKO_DEFAULT_STORE_ID=

# === Первый администратор (создаётся сидером) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
