# Скопируйте в .env и при необходимости поправьте значения.
# Этот файл читается docker compose (и для подстановки ${...}, и backend через env_file).

# === Общие секреты (обязательно сменить в проде) ===
SECRET_KEY=change-me-secret
JWT_SECRET_KEY=change-me-jwt

# === Бэкенд (Flask) ===
FLASK_ENV=production
FLASK_APP=app.py
# Путь к БД ВНУТРИ контейнера (смонтирован как volume ./back/database)
DATABASE_URL=sqlite:////app/database/database.db
# Публичный адрес бэка (для абсолютных ссылок на фото). В проде: https://api.example.com
API_BASE_URL=http://localhost:5252
# Публичный(е) домен(ы) фронта для CORS. В проде: https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Интеграция Iiko: mock | real
IIKO_MODE=mock
# Первый администратор (создаётся сидером)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# === Фронтенд (build-time) ===
# Публичный URL API, вшивается в бандл при сборке. В проде: https://api.example.com
REACT_APP_API_URL=http://localhost:5252
