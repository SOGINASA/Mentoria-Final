# Конфиг edge-детектора падений ДЛЯ ОДНОГО ЛАРЬКА.
# Скопировать в falldetect.env и заполнить под конкретную точку.
# Файл читается и run_edge.sh (Linux), и run_edge.ps1 (Windows), и systemd-юнитом.

# Адрес бэкенда (куда летят события падения). БЕЗ /api на конце.
BACKEND_URL=http://SERVER_HOST:5252

# Аккаунт-камера этой точки (роль sender, привязан к store_id точки).
# Заводится администратором заранее — см. README.
CAM_LOGIN=cam_store1
CAM_PASSWORD=changeme

# Источник видео: индекс локальной камеры (0, 1, ...) ИЛИ rtsp://... URL.
SOURCE=0

# Путь к весам детектора продуктов (Блок 1). Относительно корня репозитория
# или абсолютный. По умолчанию — обученные веса из git.
MODEL_PATH=runs/detect/runs/writeoff_detector-3/weights/best.pt

# Устройство инференса: cpu (на дешёвом мини-ПК) или 0 (GPU/Jetson).
DEVICE=cpu

# Параметры срабатывания (калибруются под ракурс камеры в ларьке).
CONF=0.3          # порог уверенности детектора
DROP_RATIO=0.22   # мин. падение нижней грани (доля высоты кадра за окно)
FLOOR_RATIO=0.2   # высота зоны пола снизу (доля кадра)
WINDOW_SEC=0.5    # окно анализа траектории, сек

# Доп. аргументы fall_detection.py (опц.), напр.:
#   --floor-polygon "[[0,400],[640,400],[640,480],[0,480]]"
#   --snapshots /var/lib/falldetect/snapshots
EXTRA_ARGS=
